# OpenEMR
OPENEMR_BASE_URL=https://openemr:443/apis/default/api
OPENEMR_FHIR_URL=https://openemr:443/apis/default/fhir
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_SITE=default

# MySQL (shared with OpenEMR)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=openemr
MYSQL_PASSWORD=openemr
MYSQL_DATABASE=openemr

# Anthropic
ANTHROPIC_API_KEY=

# Braintrust Observability (https://www.braintrust.dev)
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=CareGap

# CMS Blue Button Sandbox
BLUEBUTTON_CLIENT_ID=
BLUEBUTTON_CLIENT_SECRET=
BLUEBUTTON_BASE_URL=https://sandbox.bluebutton.cms.gov/v2/fhir
BLUEBUTTON_AUTH_URL=https://sandbox.bluebutton.cms.gov/v2/o/authorize
BLUEBUTTON_TOKEN_URL=https://sandbox.bluebutton.cms.gov/v2/o/token

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
