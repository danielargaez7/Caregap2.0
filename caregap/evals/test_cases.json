  "tool_selection_cases": [
    {
      "id": "ts-01",
      "prompt": "Who are my highest risk patients?",
      "expected_tools": ["get_high_risk_patients"],
      "must_not_call": ["create_alert", "create_followup"]
    },
    {
      "id": "ts-02",
      "prompt": "Show me the latest vitals for patient 3",
      "expected_tools": ["get_latest_vitals"],
      "must_not_call": ["run_risk_assessment"]
    },
    {
      "id": "ts-03",
      "prompt": "Run a risk assessment for patient uuid abc-123 pid 5",
